---
const DESKTOP_COLS = 5;
const MOBILE_COLS = 2;
const ROWS = 2;
const TOTAL = DESKTOP_COLS * ROWS; // 10

const tiles = Array.from({ length: TOTAL }, (_, i) => ({
  id: i,
  front: `/images/mosaic/front-${String(i + 1).padStart(2, '0')}.webp`,
  back: `/images/mosaic/back-${String(i + 1).padStart(2, '0')}.webp`,
  delay: (i * 0.7) % 8,
  // only first 4 tiles visible on mobile (2 cols × 2 rows)
  mobileHidden: i >= 4,
}));
---

<div class="mosaic-grid">
  {tiles.map((tile) => (
    <div
      class={`mosaic-tile${tile.mobileHidden ? ' hidden md:block' : ''}`}
      style={`--delay: ${tile.delay}s;`}
    >
      <div class="mosaic-card">
        <div
          class="mosaic-face mosaic-front"
          style={`background-image: url('${tile.front}');`}
        />
        <div
          class="mosaic-face mosaic-back"
          style={`background-image: url('${tile.back}');`}
        />
      </div>
    </div>
  ))}
</div>

<style>
  .mosaic-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, 1fr);
    width: 100%;
    height: 100%;
  }

  @media (min-width: 768px) {
    .mosaic-grid {
      grid-template-columns: repeat(5, 1fr);
      grid-template-rows: repeat(2, 1fr);
    }
  }

  .mosaic-tile {
    perspective: 1000px;
  }

  .mosaic-card {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* ── desktop only ── */
  @media (min-width: 768px) {
    .mosaic-tile {
      cursor: pointer;
    }

    .mosaic-card {
      transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* hover flip */
    .mosaic-tile:hover .mosaic-card {
      transform: rotateY(180deg);
    }

    /* autonomous staggered flips */
    .mosaic-card {
      animation: autoFlip 20s infinite;
      animation-delay: var(--delay);
    }
  }

  @keyframes autoFlip {
    0%, 94%, 100% { transform: rotateY(0deg); }
    97%            { transform: rotateY(180deg); }
  }

  .mosaic-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    background-size: cover;
    background-position: center;
  }

  .mosaic-back {
    transform: rotateY(180deg);
  }
</style>
